{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "paths": {
      "#angular/*": ["./angular/*"],
      "#client/*": ["./client/*"],
      "#devtools/*": ["./devtools/*"],
      "#http/*": ["./http/*"],
      "#nextjs/*": ["./nextjs/*"],
      "#node/*": ["./node/*"],
      "#react/*": ["./react/*"],
      "#solid/*": ["./solid/*"],
      "#svelte/*": ["./svelte/*"],
      "#sveltekit/*": ["./sveltekit/*"],
      "#vue/*": ["./vue/*"]
    },
    "rootDir": ".",
    "types": ["node"]
  },
  "include": [
    "angular/**/*.ts",
    "client/**/*.ts",
    "devtools/**/*.ts",
    "http/**/*.ts",
    "nextjs/**/*.ts",
    "node/**/*.ts",
    "react/**/*.ts",
    "solid/**/*.ts",
    "svelte/**/*.ts",
    "sveltekit/**/*.ts",
    "vue/**/*.ts",
    "index.ts"
  ]
}
