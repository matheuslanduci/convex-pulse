    "@sveltejs/kit": "^2.69.3",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "svelte-check": "^4.0.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.4"
  }
}
