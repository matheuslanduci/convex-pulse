  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["dom", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "paths": {
      "#benchmark/api": ["../convex/_generated/api"]
    },
    "strict": true,
    "target": "esnext",
    "types": ["vite/client"]
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
